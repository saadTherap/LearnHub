<?xml version="1.0" encoding="UTF-8"?>
<hazelcast xsi:schemaLocation="http://www.hazelcast.com/schema/config hazelcast-config-5.4.xsd"
           xmlns="http://www.hazelcast.com/schema/config"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">

    <cluster-name>learnhub</cluster-name>
    <network>
        <port auto-increment="true">5701</port>
        <join>
            <tcp-ip enabled="true">
                <member>192.168.0.215:5701</member>
                <member>192.168.0.215:5702</member>
                <member>192.168.0.215:5703</member>
                <member>172.16.2.80:5701</member>
                <member>172.16.2.80:5702</member>
                <member>172.16.2.80:5703</member>
            </tcp-ip>
            <multicast enabled="false"/>
        </join>
    </network>


    <split-brain-protection name="mapProtection" enabled="true">
        <minimum-cluster-size>2</minimum-cluster-size>
        <protect-on>WRITE</protect-on>
        <probabilistic-split-brain-protection
            acceptable-heartbeat-pause-millis="60000"
            suspicion-threshold="12"
            max-sample-size="100"
            heartbeat-interval-millis="10000"
            min-std-deviation-millis="1000"/>
    </split-brain-protection>

    <map name="courses">
        <backup-count>1</backup-count>
        <time-to-live-seconds>1800</time-to-live-seconds>
        <eviction eviction-policy="LRU" max-size-policy="PER_NODE" size="10000"/>
        <merge-policy batch-size="100">DiscardMergePolicy</merge-policy>
        <split-brain-protection-ref>mapProtection</split-brain-protection-ref>
    </map>

    <map name="courseCatalog">
        <backup-count>1</backup-count>
        <time-to-live-seconds>1800</time-to-live-seconds>
        <eviction eviction-policy="LRU" max-size-policy="PER_NODE" size="10000"/>
        <merge-policy batch-size="100">DiscardMergePolicy</merge-policy>
        <split-brain-protection-ref>mapProtection</split-brain-protection-ref>
    </map>

    <map name="instructors">
        <backup-count>1</backup-count>
        <time-to-live-seconds>900</time-to-live-seconds>
        <eviction eviction-policy="LRU" max-size-policy="PER_NODE" size="5000"/>
        <merge-policy batch-size="100">DiscardMergePolicy</merge-policy>
        <split-brain-protection-ref>mapProtection</split-brain-protection-ref>
    </map>

    <map name="instructorCatalog">
        <backup-count>1</backup-count>
        <time-to-live-seconds>900</time-to-live-seconds>
        <eviction eviction-policy="LRU" max-size-policy="PER_NODE" size="5000"/>
        <merge-policy batch-size="100">DiscardMergePolicy</merge-policy>
        <split-brain-protection-ref>mapProtection</split-brain-protection-ref>
    </map>

    <map name="modules">
        <backup-count>1</backup-count>
        <time-to-live-seconds>900</time-to-live-seconds>
        <eviction eviction-policy="LRU" max-size-policy="PER_NODE" size="5000"/>
        <merge-policy batch-size="100">DiscardMergePolicy</merge-policy>
        <split-brain-protection-ref>mapProtection</split-brain-protection-ref>
    </map>

    <map name="userEpoch">
        <backup-count>1</backup-count>
        <time-to-live-seconds>900</time-to-live-seconds>
        <eviction eviction-policy="LRU" max-size-policy="PER_NODE" size="5000"/>
        <merge-policy batch-size="100">DiscardMergePolicy</merge-policy>
        <split-brain-protection-ref>mapProtection</split-brain-protection-ref>
    </map>

    <management-center console-enabled="true" scripting-enabled="true"/>

</hazelcast>
